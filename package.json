{
  "name": "background-tasks",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.11",
  "workspaces": [
    "packages/*",
    "apps/*"
  ],
  "scripts": {
    "dev": "bun run apps/cli/src/cli.ts",
    "test": "bun test",
    "typecheck": "tsc --noEmit",
    "build": "bun build apps/cli/src/cli.ts apps/opencode-plugin/src/server.ts apps/opencode-tui/src/tui.ts --outdir dist --target bun --format esm --external @opencode-ai/plugin --external @opencode-ai/plugin/tui"
  },
  "dependencies": {
    "@effect/platform": "^0.96.0",
    "@effect/platform-bun": "^0.89.0",
    "@effect/platform-node": "^0.94.0",
    "@effect/cli": "^0.75.0",
    "effect": "^3.21.0"
  },
  "devDependencies": {
    "@opencode-ai/plugin": "^1.4.0",
    "@types/bun": "^1.3.11",
    "typescript": "^6.0.3"
  },
  "peerDependencies": {
    "@opencode-ai/plugin": ">=1.4.0"
  }
}
